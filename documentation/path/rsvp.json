{
  "paths": {
    "/api/rsvp": {
      "post": {
        "tags": ["RSVP"],
        "summary": "Submit RSVP dari tamu (public)",
        "operationId": "rsvpSubmit",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["guest_id", "invitation_id", "status"],
              "properties": {
                "guest_id": { "type": "string", "example": "ca7fea1a-6aa9-4dd1-83ab-d0fd0a3a39b7" },
                "invitation_id": { "type": "string", "example": "4a3bf159-70dd-4b30-abd6-aeee740d20bc" },
                "status": { "type": "string", "enum": ["hadir", "tidak", "mungkin"], "example": "hadir" },
                "total_persons": { "type": "integer", "example": 2 },
                "message": { "type": "string", "example": "Insya Allah kami hadir!" }
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "RSVP berhasil disubmit" }
        }
      }
    },
    "/api/rsvp/invitation/{invitationId}": {
      "get": {
        "tags": ["RSVP"],
        "summary": "List semua RSVP per undangan",
        "operationId": "rsvpFindAll",
        "produces": ["application/json"],
        "parameters": [
          { "in": "path", "name": "invitationId", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "List RSVP" }
        },
        "security": [{ "Bearer": [] }]
      }
    }
  }
}
