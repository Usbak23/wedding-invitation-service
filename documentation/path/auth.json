{
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register user baru",
        "operationId": "authRegister",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["name", "email", "password"],
              "properties": {
                "name": { "type": "string", "example": "Mubarok" },
                "email": { "type": "string", "example": "mubarok@test.com" },
                "password": { "type": "string", "example": "123456" }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Register berhasil",
            "schema": {
              "type": "object",
              "properties": {
                "success": { "example": true },
                "message": { "example": "Registration successful" },
                "data": {
                  "example": {
                    "id": "c3182f7d-66a5-4801-b382-a629152722dd",
                    "name": "Mubarok",
                    "email": "mubarok@test.com",
                    "role": "user",
                    "created_at": "2026-04-13T08:01:56.282Z"
                  }
                }
              }
            }
          },
          "409": { "description": "Email already registered" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login dan dapatkan JWT token",
        "operationId": "authLogin",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["email", "password"],
              "properties": {
                "email": { "type": "string", "example": "mubarok@test.com" },
                "password": { "type": "string", "example": "123456" }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Login berhasil",
            "schema": {
              "type": "object",
              "properties": {
                "success": { "example": true },
                "message": { "example": "Login successful" },
                "data": {
                  "example": {
                    "access_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                  }
                }
              }
            }
          },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get data user yang sedang login",
        "operationId": "authMe",
        "produces": ["application/json"],
        "parameters": [],
        "responses": {
          "200": {
            "description": "Data user",
            "schema": {
              "type": "object",
              "properties": {
                "success": { "example": true },
                "data": {
                  "example": {
                    "id": "c3182f7d-66a5-4801-b382-a629152722dd",
                    "name": "Mubarok",
                    "email": "mubarok@test.com",
                    "role": "user"
                  }
                }
              }
            }
          }
        },
        "security": [{ "Bearer": [] }]
      }
    }
    "/api/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Logout user",
        "operationId": "authLogout",
        "produces": ["application/json"],
        "parameters": [],
        "responses": {
          "200": {
            "description": "Logout berhasil",
            "schema": {
              "type": "object",
              "properties": {
                "success": { "example": true },
                "message": { "example": "Logout successful" },
                "data": { "example": null }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        },
        "security": [{ "Bearer": [] }]
      }
    }
  }
}
